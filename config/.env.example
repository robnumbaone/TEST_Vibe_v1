# Environment Template
# Copia questo file in .env e riempi i valori

# Development
NODE_ENV=development
DEBUG=false

# API
API_PORT=3000
API_URL=http://localhost:3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vibedb
DB_USER=postgres
DB_PASSWORD=password

# Authentication
JWT_SECRET=your-secret-key-here
JWT_EXPIRY=24h

# External Services
# [Aggiungi qui le tue API keys, tokens, etc.]

# Logging
LOG_LEVEL=info
